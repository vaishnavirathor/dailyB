# Daily Bread — backend keys (copy to .env, never commit .env)
#
# Without these the app runs community features in OFFLINE PREVIEW mode.
# To go live:
#   1. Create a free project at https://supabase.com
#   2. Authentication → Providers → enable "Anonymous sign-ins"
#   3. SQL Editor → run supabase/schema.sql
#   4. Project Settings → API → copy the two values below
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── HD voice (optional, "the pastor voice") ─────────────────────────
# The provider API keys are SERVER-side secrets, never in this file.
# Setup (after the Supabase project exists):
#   1. supabase functions deploy tts
#   2. Storage → create PUBLIC bucket: tts-cache
#   3. supabase secrets set TTS_DEFAULT_PROVIDER=azure \
#        AZURE_SPEECH_KEY=… AZURE_SPEECH_REGION=centralindia
#      (and/or SARVAM_API_KEY=…, ELEVENLABS_API_KEY=… +
#       ELEVEN_VOICE_TE=… ELEVEN_VOICE_EN=… for a cloned pastor voice)
#   4. In the app: Settings → Read-aloud voice → HD voice ON

# ── DEV ONLY: hear HD voices before the backend exists ──────────────
# These call Azure/Sarvam directly from the device. The keys land in
# the JS bundle — NEVER ship a build with these set. Delete them once
# the Supabase edge function is live (it takes precedence anyway).
#
# Azure: portal.azure.com → create "Speech service" (free F0) → Keys
EXPO_PUBLIC_DEV_AZURE_SPEECH_KEY=
EXPO_PUBLIC_DEV_AZURE_SPEECH_REGION=centralindia
# Sarvam: dashboard.sarvam.ai → API Keys (free credits on signup)
EXPO_PUBLIC_DEV_SARVAM_API_KEY=
