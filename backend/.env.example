# Supabase (service_role key — keep secret, never ship to client)
SUPABASE_URL=https://roruesavqqgposspirpv.supabase.co
SUPABASE_SERVICE_KEY=sb_service_<your_service_role_key>

# JWT secret for issuing app tokens
APP_JWT_SECRET=<random_64_char_hex>

# GCS bucket for event analytics (optional — omitting writes to console)
GCS_EVENTS_BUCKET=daily-bread-events

# Port
PORT=8080
