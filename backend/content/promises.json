{
  "general": [
    { "id": "g001", "category": "hope", "reference": { "en": "Jeremiah 29:11", "te": "\u0c2f\u0c3f\u0c30\u0c4d\u0c2e\u0c40\u0c2f\u0c3e 29:11" }, "text": { "en": "For I know the thoughts that I think toward you, saith the LORD, thoughts of peace, and not of evil, to give you an expected end.", "te": "\u0c28\u0c47\u0c28\u0c41 \u0c2e\u0c3f\u0c2e\u0c4d\u0c2e\u0c41\u0c28\u0c41\u0c17\u0c42\u0c30\u0c3f\u0c1a\u0c3f \u0c09\u0c26\u0c4d\u0c26\u0c47\u0c36\u0c3f\u0c02\u0c1a\u0c41 \u0c38\u0c02\u0c17\u0c24\u0c41\u0c32\u0c28\u0c41 \u0c28\u0c47\u0c28\u0c46\u0c30\u0c41\u0c17\u0c41\u0c26\u0c41\u0c28\u0c41; \u0c30\u0c3e\u0c2c\u0c4b\u0c35\u0c41 \u0c15\u0c3e\u0c32\u0c2e\u0c41\u0c02\u0c26\u0c41 \u0c2e\u0c40\u0c15\u0c41 \u0c28\u0c3f\u0c30\u0c40\u0c15\u0c4d\u0c37\u0c23 \u0c15\u0c32\u0c41\u0c17\u0c41\u0c28\u0c1f\u0c4d\u0c32\u0c41\u0c17\u0c3e \u0c05\u0c35\u0c3f \u0c38\u0c2e\u0c3e\u0c27\u0c3e\u0c28\u0c15\u0c30\u0c2e\u0c48\u0c28 \u0c09\u0c26\u0c4d\u0c26\u0c47\u0c36\u0c2e\u0c41\u0c32\u0c47 \u0c17\u0c3e\u0c28\u0c3f \u0c39\u0c3e\u0c28\u0c3f\u0c15\u0c30\u0c2e\u0c48\u0c28\u0c35\u0c3f \u0c15\u0c3e\u0c35\u0c41; \u0c07\u0c26\u0c47 \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e \u0c35\u0c3e\u0c15\u0c4d\u0c15\u0c41." } },
    { "id": "g002", "category": "hope", "reference": { "en": "Isaiah 40:31", "te": "\u0c2f\u0c46\u0c37\u0c2f\u0c3e 40:31" }, "text": { "en": "But they that wait upon the LORD shall renew their strength; they shall mount up with wings as eagles; they shall run, and not be weary; and they shall walk, and not faint.", "te": "\u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e\u0c15\u0c4a\u0c30\u0c15\u0c41 \u0c0e\u0c26\u0c41\u0c30\u0c41\u0c1a\u0c42\u0c1a\u0c41\u0c35\u0c3e\u0c30\u0c41 \u0c28\u0c42\u0c24\u0c28 \u0c2c\u0c32\u0c2e\u0c41 \u0c2a\u0c4a\u0c02\u0c26\u0c41\u0c26\u0c41\u0c30\u0c41; \u0c35\u0c3e\u0c30\u0c41 \u0c2a\u0c15\u0c4d\u0c37\u0c3f\u0c30\u0c3e\u0c1c\u0c41\u0c32\u0c35\u0c32\u0c46 \u0c30\u0c46\u0c15\u0c4d\u0c15\u0c32\u0c41 \u0c1a\u0c3e\u0c2a\u0c3f \u0c2a\u0c48\u0c15\u0c3f \u0c0e\u0c17\u0c41\u0c30\u0c41\u0c26\u0c41\u0c30\u0c41; \u0c05\u0c32\u0c2f\u0c15 \u0c2a\u0c30\u0c41\u0c17\u0c46\u0c24\u0c4d\u0c24\u0c41\u0c26\u0c41\u0c30\u0c41, \u0c38\u0c4a\u0c2e\u0c4d\u0c2e\u0c38\u0c3f\u0c32\u0c4d\u0c32\u0c15 \u0c28\u0c21\u0c3f\u0c1a\u0c3f\u0c2a\u0c4b\u0c35\u0c41\u0c26\u0c41\u0c30\u0c41." } },
    { "id": "g003", "category": "hope", "reference": { "en": "Romans 15:13", "te": "\u0c30\u0c4b\u0c2e\u0c40\u0c2f\u0c41\u0c32\u0c15\u0c41 15:13" }, "text": { "en": "Now the God of hope fill you with all joy and peace in believing, that ye may abound in hope, through the power of the Holy Ghost.", "te": "\u0c2e\u0c40\u0c30\u0c41 \u0c2a\u0c30\u0c3f\u0c36\u0c41\u0c26\u0c4d\u0c27\u0c3e\u0c24\u0c4d\u0c2e \u0c36\u0c15\u0c4d\u0c24\u0c3f \u0c2a\u0c4a\u0c02\u0c26\u0c3f, \u0c35\u0c3f\u0c38\u0c4d\u0c24\u0c3e\u0c30\u0c2e\u0c41\u0c17\u0c3e \u0c28\u0c3f\u0c30\u0c40\u0c15\u0c4d\u0c37\u0c23 \u0c17\u0c32\u0c35\u0c3e\u0c30\u0c17\u0c41\u0c1f\u0c15\u0c41 \u0c28\u0c3f\u0c30\u0c40\u0c15\u0c4d\u0c37\u0c23\u0c15\u0c30\u0c4d\u0c24\u0c2f\u0c3e\u0c17\u0c41 \u0c26\u0c47\u0c35\u0c41\u0c21\u0c41 \u0c35\u0c3f\u0c36\u0c4d\u0c35\u0c3e\u0c38\u0c2e\u0c41 \u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c3e \u0c38\u0c2e\u0c38\u0c4d\u0c24\u0c3e\u0c28\u0c02\u0c26\u0c2e\u0c41\u0c24\u0c4b\u0c28\u0c41 \u0c38\u0c2e\u0c3e\u0c27\u0c3e\u0c28\u0c2e\u0c41\u0c24\u0c4b\u0c28\u0c41 \u0c2e\u0c3f\u0c2e\u0c4d\u0c2e\u0c41\u0c28\u0c41 \u0c28\u0c3f\u0c02\u0c2a\u0c41\u0c28\u0c41 \u0c17\u0c3e\u0c15." } },
    { "id": "g004", "category": "provision", "reference": { "en": "Philippians 4:19", "te": "\u0c2b\u0c3f\u0c32\u0c3f\u0c2a\u0c4d\u0c2a\u0c40\u0c2f\u0c41\u0c32\u0c15\u0c41 4:19" }, "text": { "en": "But my God shall supply all your need according to his riches in glory by Christ Jesus.", "te": "\u0c15\u0c3e\u0c17\u0c3e \u0c26\u0c47\u0c35\u0c41\u0c21\u0c41 \u0c24\u0c28 \u0c10\u0c36\u0c4d\u0c35\u0c30\u0c4d\u0c2f\u0c2e\u0c41 \u0c1a\u0c4a\u0c2a\u0c4d\u0c2a\u0c41\u0c28 \u0c15\u0c4d\u0c30\u0c40\u0c38\u0c4d\u0c24\u0c41\u0c2f\u0c47\u0c38\u0c41\u0c28\u0c02\u0c26\u0c41 \u0c2e\u0c39\u0c3f\u0c2e\u0c32\u0c4b \u0c2e\u0c40 \u0c2a\u0c4d\u0c30\u0c24\u0c3f \u0c05\u0c35\u0c38\u0c30\u0c2e\u0c41\u0c28\u0c41 \u0c24\u0c40\u0c30\u0c4d\u0c1a\u0c41\u0c28\u0c41." } },
    { "id": "g005", "category": "provision", "reference": { "en": "Matthew 6:33", "te": "\u0c2e\u0c24\u0c4d\u0c24\u0c2f\u0c3f 6:33" }, "text": { "en": "But seek ye first the kingdom of God, and his righteousness; and all these things shall be added unto you.", "te": "\u0c15\u0c3e\u0c2c\u0c1f\u0c4d\u0c1f\u0c3f \u0c2e\u0c40\u0c30\u0c41 \u0c06\u0c2f\u0c28 \u0c30\u0c3e\u0c1c\u0c4d\u0c2f\u0c2e\u0c41\u0c28\u0c41 \u0c28\u0c40\u0c24\u0c3f\u0c28\u0c3f \u0c2e\u0c4a\u0c26\u0c1f \u0c35\u0c46\u0c26\u0c15\u0c41\u0c21\u0c3f; \u0c05\u0c2a\u0c4d\u0c2a\u0c41\u0c21\u0c35\u0c28\u0c4d\u0c28\u0c3f\u0c2f\u0c41 \u0c2e\u0c40\u0c15\u0c28\u0c41\u0c17\u0c4d\u0c30\u0c39\u0c3f\u0c02\u0c2a\u0c2c\u0c21\u0c41\u0c28\u0c41." } },
    { "id": "g006", "category": "provision", "reference": { "en": "Psalm 34:10", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 34:10" }, "text": { "en": "The young lions do lack, and suffer hunger: but they that seek the LORD shall not want any good thing.", "te": "\u0c38\u0c3f\u0c02\u0c39\u0c2a\u0c41 \u0c2a\u0c3f\u0c32\u0c4d\u0c32\u0c32\u0c41 \u0c32\u0c47\u0c2e\u0c3f\u0c17\u0c32\u0c35\u0c48 \u0c06\u0c15\u0c32\u0c3f\u0c17\u0c4a\u0c28\u0c41\u0c28\u0c41 \u0c17\u0c3e\u0c28\u0c3f \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e\u0c28\u0c41 \u0c06\u0c36\u0c4d\u0c30\u0c2f\u0c3f\u0c02\u0c1a\u0c41\u0c35\u0c3e\u0c30\u0c3f\u0c15\u0c3f \u0c0f \u0c2e\u0c47\u0c32\u0c41 \u0c15\u0c4a\u0c26\u0c41\u0c35\u0c17\u0c48 \u0c2f\u0c41\u0c02\u0c21\u0c26\u0c41." } },
    { "id": "g007", "category": "healing", "reference": { "en": "Psalm 147:3", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 147:3" }, "text": { "en": "He healeth the broken in heart, and bindeth up their wounds.", "te": "\u0c17\u0c41\u0c02\u0c21\u0c46 \u0c1a\u0c46\u0c26\u0c3f\u0c30\u0c3f\u0c28\u0c35\u0c3e\u0c30\u0c3f\u0c28\u0c3f \u0c06\u0c2f\u0c28 \u0c2c\u0c3e\u0c17\u0c41\u0c1a\u0c47\u0c2f\u0c41\u0c35\u0c3e\u0c21\u0c41; \u0c35\u0c3e\u0c30\u0c3f \u0c17\u0c3e\u0c2f\u0c2e\u0c41\u0c32\u0c28\u0c41 \u0c15\u0c1f\u0c4d\u0c1f\u0c41\u0c35\u0c3e\u0c21\u0c41." } },
    { "id": "g008", "category": "healing", "reference": { "en": "Isaiah 53:5", "te": "\u0c2f\u0c46\u0c37\u0c2f\u0c3e 53:5" }, "text": { "en": "But he was wounded for our transgressions, he was bruised for our iniquities: the chastisement of our peace was upon him; and with his stripes we are healed.", "te": "\u0c2e\u0c28 \u0c05\u0c24\u0c3f\u0c15\u0c4d\u0c30\u0c2e \u0c15\u0c4d\u0c30\u0c3f\u0c2f\u0c32\u0c28\u0c41\u0c2c\u0c1f\u0c4d\u0c1f\u0c3f \u0c05\u0c24\u0c21\u0c41 \u0c17\u0c3e\u0c2f\u0c2a\u0c30\u0c1a\u0c2c\u0c21\u0c46\u0c28\u0c41; \u0c2e\u0c28 \u0c26\u0c4b\u0c37\u0c2e\u0c41\u0c32\u0c28\u0c41\u0c2c\u0c1f\u0c4d\u0c1f\u0c3f \u0c28\u0c32\u0c41\u0c17\u0c17\u0c4a\u0c1f\u0c4d\u0c1f\u0c2c\u0c21\u0c46\u0c28\u0c41; \u0c2e\u0c28 \u0c38\u0c2e\u0c3e\u0c27\u0c3e\u0c28\u0c3e\u0c30\u0c4d\u0c25\u0c2e\u0c48\u0c28 \u0c36\u0c3f\u0c15\u0c4d\u0c37 \u0c05\u0c24\u0c28\u0c3f\u0c2e\u0c40\u0c26 \u0c2a\u0c21\u0c46\u0c28\u0c41; \u0c05\u0c24\u0c21\u0c41 \u0c2a\u0c4a\u0c02\u0c26\u0c3f\u0c28 \u0c26\u0c46\u0c2c\u0c4d\u0c2c\u0c32\u0c1a\u0c47\u0c24 \u0c2e\u0c28\u0c15\u0c41 \u0c38\u0c4d\u0c35\u0c38\u0c4d\u0c25\u0c24 \u0c15\u0c32\u0c41\u0c17\u0c41\u0c1a\u0c41\u0c28\u0c4d\u0c28\u0c26\u0c3f." } },
    { "id": "g009", "category": "victory", "reference": { "en": "1 Corinthians 15:57", "te": "1 \u0c15\u0c4a\u0c30\u0c3f\u0c02\u0c25\u0c40\u0c2f\u0c41\u0c32\u0c15\u0c41 15:57" }, "text": { "en": "But thanks be to God, which giveth us the victory through our Lord Jesus Christ.", "te": "\u0c2e\u0c28 \u0c2a\u0c4d\u0c30\u0c2d\u0c41\u0c35\u0c48\u0c28 \u0c2f\u0c47\u0c38\u0c41\u0c15\u0c4d\u0c30\u0c40\u0c38\u0c4d\u0c24\u0c41 \u0c2e\u0c42\u0c32\u0c2e\u0c41\u0c17\u0c3e \u0c2e\u0c28\u0c15\u0c41 \u0c1c\u0c2f\u0c2e\u0c41 \u0c05\u0c28\u0c41\u0c17\u0c4d\u0c30\u0c39\u0c3f\u0c02\u0c1a\u0c41\u0c1a\u0c41\u0c28\u0c4d\u0c28 \u0c26\u0c47\u0c35\u0c41\u0c28\u0c3f\u0c15\u0c3f \u0c38\u0c4d\u0c24\u0c4b\u0c24\u0c4d\u0c30\u0c2e\u0c41 \u0c15\u0c32\u0c41\u0c17\u0c41\u0c28\u0c41 \u0c17\u0c3e\u0c15." } },
    { "id": "g010", "category": "victory", "reference": { "en": "Romans 8:37", "te": "\u0c30\u0c4b\u0c2e\u0c40\u0c2f\u0c41\u0c32\u0c15\u0c41 8:37" }, "text": { "en": "Nay, in all these things we are more than conquerors through him that loved us.", "te": "\u0c05\u0c2f\u0c3f\u0c28\u0c28\u0c41 \u0c2e\u0c28\u0c32\u0c28\u0c41 \u0c2a\u0c4d\u0c30\u0c47\u0c2e\u0c3f\u0c02\u0c1a\u0c3f\u0c28\u0c35\u0c3e\u0c28\u0c3f \u0c26\u0c4d\u0c35\u0c3e\u0c30\u0c3e \u0c2e\u0c28\u0c2e\u0c41 \u0c35\u0c40\u0c1f\u0c28\u0c4d\u0c28\u0c3f\u0c1f\u0c3f\u0c32\u0c4b \u0c05\u0c24\u0c4d\u0c2f\u0c27\u0c3f\u0c15 \u0c35\u0c3f\u0c1c\u0c2f\u0c2e\u0c41 \u0c2a\u0c4a\u0c02\u0c26\u0c41\u0c1a\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c2e\u0c41." } },
    { "id": "g011", "category": "hope", "reference": { "en": "Psalm 42:11", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 42:11" }, "text": { "en": "Hope thou in God: for I shall yet praise him, who is the health of my countenance, and my God.", "te": "\u0c26\u0c47\u0c35\u0c41\u0c28\u0c3f\u0c2f\u0c02\u0c26\u0c41 \u0c28\u0c3f\u0c30\u0c40\u0c15\u0c4d\u0c37\u0c23 \u0c2f\u0c41\u0c02\u0c1a\u0c41\u0c2e\u0c41; \u0c06\u0c2f\u0c28 \u0c28\u0c3e \u0c30\u0c15\u0c4d\u0c37\u0c23\u0c15\u0c30\u0c4d\u0c24, \u0c28\u0c3e \u0c26\u0c47\u0c35\u0c41\u0c21\u0c41 \u0c05\u0c28\u0c3f \u0c28\u0c47\u0c28\u0c41 \u0c07\u0c02\u0c15\u0c28\u0c41 \u0c06\u0c2f\u0c28\u0c28\u0c41 \u0c38\u0c4d\u0c24\u0c41\u0c24\u0c3f\u0c02\u0c1a\u0c46\u0c26\u0c28\u0c41." } },
    { "id": "g012", "category": "hope", "reference": { "en": "1 Peter 5:7", "te": "1 \u0c2a\u0c47\u0c24\u0c41\u0c30\u0c41 5:7" }, "text": { "en": "Casting all your care upon him; for he careth for you.", "te": "\u0c06\u0c2f\u0c28 \u0c2e\u0c3f\u0c2e\u0c4d\u0c2e\u0c41\u0c28\u0c41\u0c17\u0c42\u0c30\u0c3f\u0c1a\u0c3f \u0c1a\u0c3f\u0c02\u0c24\u0c3f\u0c02\u0c1a\u0c41\u0c1a\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c21\u0c41 \u0c17\u0c28\u0c41\u0c15 \u0c2e\u0c40 \u0c1a\u0c3f\u0c02\u0c24 \u0c2f\u0c3e\u0c35\u0c24\u0c4d\u0c24\u0c41 \u0c06\u0c2f\u0c28 \u0c2e\u0c40\u0c26 \u0c35\u0c47\u0c2f\u0c41\u0c21\u0c3f." } },
    { "id": "g013", "category": "provision", "reference": { "en": "2 Corinthians 9:8", "te": "2 \u0c15\u0c4a\u0c30\u0c3f\u0c02\u0c25\u0c40\u0c2f\u0c41\u0c32\u0c15\u0c41 9:8" }, "text": { "en": "And God is able to make all grace abound toward you; that ye, always having all sufficiency in all things, may abound to every good work.", "te": "\u0c2e\u0c40\u0c30\u0c41 \u0c05\u0c28\u0c4d\u0c28\u0c3f\u0c1f\u0c3f\u0c2f\u0c02\u0c26\u0c41 \u0c0e\u0c32\u0c4d\u0c32\u0c2a\u0c4d\u0c2a\u0c41\u0c21\u0c41\u0c28\u0c41 \u0c38\u0c30\u0c4d\u0c35\u0c38\u0c2e\u0c43\u0c26\u0c4d\u0c27\u0c3f\u0c17\u0c32\u0c35\u0c3e\u0c30\u0c48, \u0c09\u0c24\u0c4d\u0c24\u0c2e\u0c2e\u0c48\u0c28 \u0c2a\u0c4d\u0c30\u0c24\u0c3f \u0c15\u0c3e\u0c30\u0c4d\u0c2f\u0c2e\u0c41\u0c28\u0c15\u0c41 \u0c38\u0c3f\u0c26\u0c4d\u0c27\u0c2a\u0c21\u0c41\u0c28\u0c1f\u0c4d\u0c32\u0c41 \u0c26\u0c47\u0c35\u0c41\u0c21\u0c41 \u0c2e\u0c40\u0c2f\u0c46\u0c21\u0c32 \u0c38\u0c2e\u0c38\u0c4d\u0c24 \u0c15\u0c43\u0c2a\u0c28\u0c41 \u0c35\u0c3f\u0c38\u0c4d\u0c24\u0c30\u0c3f\u0c02\u0c2a\u0c1c\u0c47\u0c2f\u0c17\u0c32\u0c21\u0c41." } },
    { "id": "g014", "category": "healing", "reference": { "en": "Jeremiah 30:17", "te": "\u0c2f\u0c3f\u0c30\u0c4d\u0c2e\u0c40\u0c2f\u0c3e 30:17" }, "text": { "en": "For I will restore health unto thee, and I will heal thee of thy wounds, saith the LORD.", "te": "\u0c28\u0c47\u0c28\u0c41 \u0c28\u0c3f\u0c15\u0c41 \u0c06\u0c30\u0c4b\u0c17\u0c4d\u0c2f\u0c2e\u0c41 \u0c15\u0c32\u0c41\u0c17\u0c1c\u0c47\u0c38\u0c46\u0c26\u0c28\u0c41; \u0c28\u0c3f \u0c17\u0c3e\u0c2f\u0c2e\u0c41\u0c32\u0c28\u0c41 \u0c38\u0c4d\u0c35\u0c38\u0c4d\u0c25\u0c2a\u0c30\u0c1a\u0c46\u0c26\u0c28\u0c41; \u0c07\u0c26\u0c47 \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e \u0c35\u0c3e\u0c15\u0c4d\u0c15\u0c41." } },
    { "id": "g015", "category": "victory", "reference": { "en": "Deuteronomy 31:6", "te": "\u0c26\u0c4d\u0c35\u0c3f\u0c24\u0c40\u0c2f\u0c4b\u0c2a\u0c26\u0c47\u0c36\u0c15\u0c3e\u0c02\u0c21\u0c2e\u0c41 31:6" }, "text": { "en": "Be strong and of a good courage, fear not, nor be afraid of them: for the LORD thy God, he it is that doth go with thee; he will not fail thee, nor forsake thee.", "te": "\u0c28\u0c3f\u0c2c\u0c4d\u0c2c\u0c30\u0c2e\u0c41\u0c17\u0c32\u0c3f \u0c27\u0c48\u0c30\u0c4d\u0c2f\u0c2e\u0c41\u0c17\u0c3e \u0c09\u0c02\u0c21\u0c41\u0c21\u0c3f; \u0c2d\u0c2f\u0c2a\u0c21\u0c15\u0c41\u0c21\u0c3f, \u0c35\u0c3e\u0c30\u0c3f\u0c28\u0c3f \u0c1a\u0c42\u0c1a\u0c3f \u0c26\u0c3f\u0c17\u0c41\u0c32\u0c41\u0c2a\u0c21\u0c15\u0c41\u0c21\u0c3f; \u0c28\u0c40\u0c24\u0c4b \u0c15\u0c42\u0c21 \u0c35\u0c1a\u0c4d\u0c1a\u0c41\u0c35\u0c3e\u0c21\u0c41 \u0c28\u0c40 \u0c26\u0c47\u0c35\u0c41\u0c21\u0c48\u0c28 \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e\u0c2f\u0c47; \u0c06\u0c2f\u0c28 \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c35\u0c3f\u0c21\u0c41\u0c35\u0c21\u0c41, \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c0e\u0c21\u0c2c\u0c3e\u0c2f\u0c21\u0c41." } },
    { "id": "g016", "category": "victory", "reference": { "en": "2 Timothy 1:7", "te": "2 \u0c24\u0c3f\u0c2e\u0c4b\u0c24\u0c3f\u0c15\u0c3f 1:7" }, "text": { "en": "For God hath not given us the spirit of fear; but of power, and of love, and of a sound mind.", "te": "\u0c26\u0c47\u0c35\u0c41\u0c21\u0c41 \u0c2e\u0c28\u0c15\u0c41 \u0c36\u0c15\u0c4d\u0c24\u0c3f\u0c2f\u0c41 \u0c2a\u0c4d\u0c30\u0c47\u0c2e\u0c2f\u0c41 \u0c07\u0c02\u0c26\u0c4d\u0c30\u0c3f\u0c2f\u0c28\u0c3f\u0c17\u0c4d\u0c30\u0c39\u0c2e\u0c41\u0c17\u0c32 \u0c06\u0c24\u0c4d\u0c2e\u0c28\u0c41\u0c28\u0c47 \u0c07\u0c1a\u0c4d\u0c1a\u0c46\u0c28\u0c41 \u0c17\u0c3e\u0c28\u0c3f \u0c2d\u0c2f\u0c2e\u0c41\u0c17\u0c32 \u0c06\u0c24\u0c4d\u0c2e\u0c28\u0c41\u0c28\u0c41 \u0c07\u0c2f\u0c4d\u0c2f\u0c32\u0c47\u0c26\u0c41." } },
    { "id": "g017", "category": "provision", "reference": { "en": "Psalm 37:25", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 37:25" }, "text": { "en": "I have been young, and now am old; yet have I not seen the righteous forsaken, nor his seed begging bread.", "te": "\u0c28\u0c47\u0c28\u0c41 \u0c1a\u0c3f\u0c28\u0c4d\u0c28\u0c35\u0c3e\u0c21\u0c28\u0c48 \u0c2f\u0c41\u0c02\u0c1f\u0c3f\u0c28\u0c3f, \u0c07\u0c2a\u0c4d\u0c2a\u0c41\u0c21\u0c41 \u0c2e\u0c41\u0c38\u0c32\u0c3f\u0c35\u0c3e\u0c21\u0c28\u0c48\u0c24\u0c3f\u0c28\u0c3f; \u0c05\u0c2f\u0c3f\u0c28\u0c28\u0c41 \u0c28\u0c40\u0c24\u0c3f\u0c2e\u0c02\u0c24\u0c41\u0c21\u0c41 \u0c35\u0c3f\u0c21\u0c41\u0c35\u0c2c\u0c21\u0c41\u0c1f \u0c17\u0c3e\u0c28\u0c3f, \u0c05\u0c24\u0c28\u0c3f \u0c38\u0c02\u0c24\u0c3e\u0c28\u0c2e\u0c41 \u0c2d\u0c3f\u0c15\u0c4d\u0c37\u0c2e\u0c46\u0c24\u0c4d\u0c24\u0c41\u0c1f \u0c17\u0c3e\u0c28\u0c3f \u0c28\u0c47\u0c28\u0c41 \u0c1a\u0c42\u0c21\u0c32\u0c47\u0c26\u0c41." } },
    { "id": "g018", "category": "healing", "reference": { "en": "Psalm 103:2-3", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 103:2-3" }, "text": { "en": "Bless the LORD, O my soul, and forget not all his benefits: who forgiveth all thine iniquities; who healeth all thy diseases.", "te": "\u0c28\u0c3e \u0c2a\u0c4d\u0c30\u0c3e\u0c23\u0c2e\u0c3e, \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e\u0c28\u0c41 \u0c38\u0c28\u0c4d\u0c28\u0c41\u0c24\u0c3f\u0c02\u0c1a\u0c41\u0c2e\u0c41; \u0c06\u0c2f\u0c28 \u0c1a\u0c47\u0c38\u0c3f\u0c28 \u0c09\u0c2a\u0c15\u0c3e\u0c30\u0c2e\u0c41\u0c32\u0c32\u0c4b \u0c26\u0c47\u0c28\u0c3f\u0c28\u0c3f \u0c2e\u0c30\u0c41\u0c35\u0c15\u0c41\u0c2e\u0c41. \u0c06\u0c2f\u0c28 \u0c28\u0c40 \u0c26\u0c4b\u0c37\u0c2e\u0c41\u0c32\u0c28\u0c4d\u0c28\u0c3f\u0c1f\u0c3f\u0c28\u0c3f \u0c15\u0c4d\u0c37\u0c2e\u0c3f\u0c02\u0c1a\u0c41\u0c35\u0c3e\u0c21\u0c41; \u0c28\u0c40 \u0c38\u0c02\u0c15\u0c1f\u0c2e\u0c41\u0c32\u0c28\u0c4d\u0c28\u0c3f\u0c1f\u0c3f\u0c28\u0c3f \u0c15\u0c41\u0c26\u0c41\u0c30\u0c41\u0c1a\u0c41\u0c35\u0c3e\u0c21\u0c41." } },
    { "id": "g019", "category": "victory", "reference": { "en": "Psalm 18:2", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 18:2" }, "text": { "en": "The LORD is my rock, and my fortress, and my deliverer; my God, my strength, in whom I will trust.", "te": "\u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e \u0c28\u0c3e \u0c36\u0c48\u0c32\u0c2e\u0c41, \u0c28\u0c3e \u0c15\u0c4b\u0c1f, \u0c28\u0c28\u0c4d\u0c28\u0c41 \u0c30\u0c15\u0c4d\u0c37\u0c3f\u0c02\u0c1a\u0c41\u0c35\u0c3e\u0c21\u0c41; \u0c28\u0c3e \u0c26\u0c47\u0c35\u0c41\u0c21\u0c41, \u0c28\u0c47\u0c28\u0c41 \u0c06\u0c36\u0c4d\u0c30\u0c2f\u0c3f\u0c02\u0c1a\u0c3f\u0c28 \u0c28\u0c3e \u0c26\u0c41\u0c30\u0c4d\u0c17\u0c2e\u0c41." } },
    { "id": "g020", "category": "healing", "reference": { "en": "3 John 1:2", "te": "3 \u0c2f\u0c4b\u0c39\u0c3e\u0c28\u0c41 1:2" }, "text": { "en": "Beloved, I wish above all things that thou mayest prosper and be in health, even as thy soul prospereth.", "te": "\u0c2a\u0c4d\u0c30\u0c3f\u0c2f\u0c41\u0c21\u0c3e, \u0c28\u0c40 \u0c06\u0c24\u0c4d\u0c2e \u0c35\u0c30\u0c4d\u0c27\u0c3f\u0c32\u0c4d\u0c32\u0c41\u0c1a\u0c41\u0c28\u0c4d\u0c28 \u0c2a\u0c4d\u0c30\u0c15\u0c3e\u0c30\u0c2e\u0c41 \u0c28\u0c40\u0c35\u0c41 \u0c05\u0c28\u0c4d\u0c28\u0c3f \u0c35\u0c3f\u0c37\u0c2f\u0c2e\u0c41\u0c32\u0c32\u0c4b\u0c28\u0c41 \u0c35\u0c30\u0c4d\u0c27\u0c3f\u0c32\u0c4d\u0c32\u0c41\u0c1a\u0c41 \u0c06\u0c30\u0c4b\u0c17\u0c4d\u0c2f\u0c2e\u0c41\u0c17\u0c3e \u0c09\u0c02\u0c21\u0c35\u0c32\u0c38\u0c3f\u0c28\u0c3f \u0c2a\u0c4d\u0c30\u0c3e\u0c30\u0c4d\u0c25\u0c3f\u0c02\u0c1a\u0c41\u0c1a\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c28\u0c41." } }
  ],
  "gender": {
    "male": [
      { "id": "m001", "category": "hope", "reference": { "en": "Joshua 1:9", "te": "\u0c2f\u0c4b\u0c37\u0c4d\u0c2f 1:9" }, "text": { "en": "Be strong and of a good courage; be not afraid, neither be thou dismayed: for the LORD thy God is with thee whithersoever thou goest.", "te": "\u0c28\u0c3f\u0c2c\u0c4d\u0c2c\u0c30\u0c2e\u0c41\u0c17\u0c3e \u0c09\u0c02\u0c21\u0c41\u0c2e\u0c41, \u0c27\u0c48\u0c30\u0c4d\u0c2f\u0c2e\u0c41\u0c17\u0c3e \u0c09\u0c02\u0c21\u0c41\u0c2e\u0c41; \u0c28\u0c40\u0c35\u0c41 \u0c0e\u0c15\u0c4d\u0c15\u0c21 \u0c1a\u0c46\u0c32\u0c4d\u0c32\u0c3f\u0c28\u0c3e \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c28\u0c3f\u0c2e\u0c4d\u0c2e\u0c28\u0c2a\u0c30\u0c1a\u0c41\u0c35\u0c3e\u0c21\u0c41 \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c35\u0c3f\u0c21\u0c41\u0c35\u0c21\u0c41." } },
      { "id": "m002", "category": "provision", "reference": { "en": "Proverbs 3:9-10", "te": "\u0c38\u0c42\u0c15\u0c4d\u0c24\u0c3f\u0c2e\u0c41\u0c32\u0c41 3:9-10" }, "text": { "en": "Honour the LORD with thy substance, and with the firstfruits of all thine increase: So shall thy barns be filled with plenty.", "te": "\u0c28\u0c40 \u0c10\u0c36\u0c4d\u0c35\u0c30\u0c4d\u0c2f\u0c2e\u0c41\u0c26\u0c4d\u0c26\u0c3e, \u0c28\u0c40 \u0c06\u0c26\u0c3e\u0c2f\u0c2e\u0c41\u0c32\u0c28\u0c4d\u0c28\u0c3f\u0c1f\u0c3f\u0c32\u0c4b \u0c2e\u0c4a\u0c26\u0c1f\u0c3f \u0c2d\u0c3e\u0c17\u0c02\u0c26\u0c4d\u0c26\u0c3e \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e\u0c28\u0c41 \u0c18\u0c28\u0c2a\u0c30\u0c1a\u0c41\u0c2e\u0c41. \u0c05\u0c2a\u0c4d\u0c2a\u0c41\u0c21\u0c41 \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c38\u0c2e\u0c43\u0c26\u0c4d\u0c27\u0c3f \u0c06\u0c36\u0c40\u0c30\u0c4d\u0c35\u0c3e\u0c26\u0c3f\u0c38\u0c4d\u0c24\u0c3e\u0c28\u0c41." } },
      { "id": "m003", "category": "victory", "reference": { "en": "Psalm 144:1", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 144:1" }, "text": { "en": "Blessed be the LORD my strength, which teacheth my hands to war, and my fingers to fight.", "te": "\u0c2f\u0c41\u0c26\u0c4d\u0c27\u0c3e\u0c28\u0c3f\u0c15\u0c3f \u0c28\u0c3e \u0c1a\u0c46\u0c24\u0c41\u0c32\u0c28\u0c41 \u0c07\u0c02\u0c1a\u0c41\u0c35\u0c3e\u0c21\u0c41, \u0c2f\u0c41\u0c26\u0c4d\u0c27\u0c2e\u0c41\u0c32\u0c15\u0c41 \u0c28\u0c3e \u0c35\u0c47\u0c33\u0c4d\u0c32\u0c28\u0c41 \u0c28\u0c47\u0c30\u0c4d\u0c2a\u0c41\u0c35\u0c3e\u0c21\u0c41 \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e\u0c15\u0c3f \u0c38\u0c4d\u0c24\u0c4b\u0c24\u0c4d\u0c30\u0c2e\u0c41." } },
      { "id": "m004", "category": "provision", "reference": { "en": "Psalm 128:2", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 128:2" }, "text": { "en": "For thou shalt eat the labour of thine hands: happy shalt thou be, and it shall be well with thee.", "te": "\u0c28\u0c40\u0c35\u0c41 \u0c28\u0c3f \u0c1a\u0c46\u0c24\u0c41\u0c32 \u0c2a\u0c4d\u0c30\u0c2f\u0c3e\u0c38\u0c2b\u0c32\u0c2e\u0c41 \u0c05\u0c28\u0c41\u0c2d\u0c35\u0c3f\u0c38\u0c4d\u0c24\u0c3e\u0c35\u0c41; \u0c28\u0c40\u0c35\u0c41 \u0c27\u0c28\u0c4d\u0cAF\u0c41\u0c21\u0c35\u0c41, \u0c28\u0c3f\u0c15\u0c3f \u0c36\u0c41\u0c2d\u0c2e\u0c41 \u0c15\u0c32\u0c41\u0c17\u0c41\u0c28\u0c41." } },
      { "id": "m005", "category": "healing", "reference": { "en": "Psalm 34:17-18", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 34:17-18" }, "text": { "en": "The righteous cry, and the LORD heareth, and delivereth them out of all their troubles. The LORD is nigh unto them that are of a broken heart.", "te": "\u0c28\u0c40\u0c24\u0c3f\u0c2e\u0c02\u0c24\u0c41\u0c32\u0c41 \u0c2e\u0c4a\u0c30\u0c2c\u0c47\u0c38\u0c4d\u0c24\u0c47, \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e \u0c35\u0c3f\u0c28\u0c41\u0c24\u0c41\u0c28\u0c41; \u0c35\u0c3e\u0c30\u0c3f \u0c38\u0c2e\u0c38\u0c4d\u0c24 \u0c2c\u0c3e\u0c27\u0c32\u0c28\u0c41\u0c02\u0c21\u0c3f \u0c35\u0c3e\u0c30\u0c3f\u0c28\u0c3f \u0c06\u0c2f\u0c28 \u0c35\u0c3f\u0c21\u0c41\u0c2a\u0c3e\u0c21\u0c3f\u0c38\u0c4d\u0c24\u0c3e\u0c28\u0c41." } },
      { "id": "m006", "category": "hope", "reference": { "en": "Psalm 27:14", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 27:14" }, "text": { "en": "Wait on the LORD: be of good courage, and he shall strengthen thine heart: wait, I say, on the LORD.", "te": "\u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e\u0c15\u0c4a\u0c30\u0c15\u0c41 \u0c0e\u0c26\u0c41\u0c30\u0c41\u0c1a\u0c42\u0c30\u0c41; \u0c27\u0c48\u0c30\u0c4d\u0c2f\u0c2e\u0c41\u0c17\u0c3e \u0c09\u0c02\u0c21\u0c41; \u0c06\u0c2f\u0c28 \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c2c\u0c32\u0c2a\u0c30\u0c1a\u0c41\u0c28\u0c41." } },
      { "id": "m007", "category": "provision", "reference": { "en": "Proverbs 16:3", "te": "\u0c38\u0c42\u0c15\u0c4d\u0c24\u0c3f\u0c2e\u0c41\u0c32\u0c41 16:3" }, "text": { "en": "Commit thy works unto the LORD, and thy thoughts shall be established.", "te": "\u0c28\u0c40 \u0c15\u0c3e\u0c30\u0c4d\u0c2f\u0c3e\u0c32\u0c28\u0c41 \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e\u0c15\u0c41 \u0c05\u0c30\u0c4d\u0c2a\u0c3f\u0c02\u0c1a\u0c41; \u0c05\u0c2a\u0c4d\u0c2a\u0c41\u0c21\u0c41 \u0c28\u0c40 \u0c35\u0c47\u0c32\u0c32\u0c41 \u0c28\u0c3f\u0c32\u0c41\u0c35\u0c15\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c2f\u0c3f." } }
    ],
    "female": [
      { "id": "f001", "category": "hope", "reference": { "en": "Psalm 46:5", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 46:5" }, "text": { "en": "God is in the midst of her; she shall not be moved: God shall help her, and that right early.", "te": "\u0c26\u0c47\u0c35\u0c41\u0c21\u0c41 \u0c06\u0c2e\u0c47 \u0c2e\u0c27\u0c4d\u0c2f\u0c2e\u0c41\u0c28 \u0c09\u0c28\u0c4d\u0c28\u0c3e\u0c21\u0c41; \u0c06\u0c2e\u0c47 \u0c15\u0c41\u0c32\u0c41\u0c02\u0c1a\u0c26\u0c41; \u0c09\u0c26\u0c2f\u0c2e\u0c41\u0c28 \u0c26\u0c47\u0c35\u0c41\u0c21\u0c41 \u0c06\u0c2e\u0c47\u0c15\u0c41 \u0c38\u0c39\u0c3e\u0c2f\u0c02 \u0c1a\u0c47\u0c38\u0c4d\u0c24\u0c3e\u0c28\u0c41." } },
      { "id": "f002", "category": "provision", "reference": { "en": "Proverbs 31:25", "te": "\u0c38\u0c42\u0c15\u0c4d\u0c24\u0c3f\u0c2e\u0c41\u0c32\u0c41 31:25" }, "text": { "en": "Strength and honour are her clothing; and she shall rejoice in time to come.", "te": "\u0c06\u0c2e\u0c47 \u0c2c\u0c32\u0c2e\u0c41 \u0c2e\u0c30\u0c3f\u0c2f\u0c41 \u0c18\u0c28\u0c24\u0c28\u0c41 \u0c27\u0c30\u0c3f\u0c02\u0c1a\u0c41\u0c15\u0c41\u0c28\u0c4d\u0c28\u0c26\u0c41; \u0c30\u0c3e\u0c2c\u0c4b\u0c35\u0c41 \u0c26\u0c3f\u0c28\u0c3e\u0c32\u0c28\u0c41\u0c17\u0c42\u0c30\u0c3f\u0c1a\u0c3f \u0c06\u0c2e\u0c47 \u0c38\u0c02\u0c24\u0c4b\u0c37\u0c3f\u0c38\u0c4d\u0c24\u0c41\u0c02\u0c26\u0c3f." } },
      { "id": "f003", "category": "healing", "reference": { "en": "Isaiah 66:13", "te": "\u0c2f\u0c46\u0c37\u0c2f\u0c3e 66:13" }, "text": { "en": "As one whom his mother comforteth, so will I comfort you; and ye shall be comforted.", "te": "\u0c24\u0c32\u0c4d\u0c32\u0c3f \u0c24\u0c28 \u0c2c\u0c3f\u0c21\u0c4d\u0c21\u0c28\u0c41 \u0c06\u0c26\u0c30\u0c3f\u0c02\u0c1a\u0c41\u0c28\u0c1f\u0c4d\u0c32\u0c47, \u0c28\u0c47\u0c28\u0c41 \u0c2e\u0c3f\u0c2e\u0c4d\u0c2e\u0c41\u0c28\u0c41 \u0c06\u0c26\u0c30\u0c3f\u0c02\u0c1a\u0c47\u0c26\u0c28\u0c41; \u0c2e\u0c40\u0c30\u0c41 \u0c06\u0c26\u0c30\u0c3f\u0c02\u0c1a\u0c2c\u0c21\u0c41\u0c26\u0c41\u0c30\u0c41." } },
      { "id": "f004", "category": "victory", "reference": { "en": "Judges 5:7", "te": "\u0c28\u0c4d\u0c2f\u0c3e\u0c2f\u0c3e\u0c27\u0c3f\u0c2a\u0c24\u0c41\u0c32\u0c41 5:7" }, "text": { "en": "The inhabitants of the villages ceased, they ceased in Israel, until that I Deborah arose, that I arose a mother in Israel.", "te": "\u0c28\u0c3e\u0c28\u0c41 \u0c26\u0c47\u0c2c\u0c4b\u0c30\u0c3e \u0c2f\u0c46\u0c21\u0c4d\u0c21\u0c2a\u0c4b\u0c35\u0c41\u0c28\u0c47\u0c26\u0c3e\u0c15\u0c3e, \u0c07\u0c38\u0c4d\u0c30\u0c3e\u0c2f\u0c47\u0c32\u0c41\u0c28 \u0c24\u0c2f\u0c4d\u0c2f\u0c41\u0c28\u0c3e \u0c0e\u0c21\u0c4d\u0c1a\u0c41\u0c28\u0c47\u0c26\u0c3e\u0c15\u0c3e, \u0c09\u0c30\u0c41\u0c35\u0c3e\u0c33\u0c4d\u0c33 \u0c28\u0c3e\u0c2f\u0c15\u0c41\u0c30\u0c3e\u0c32\u0c41 \u0c28\u0c3f\u0c32\u0c4d\u0c1a\u0c3f\u0c2a\u0c4b\u0c2f\u0c3e\u0c30\u0c41." } },
      { "id": "f005", "category": "provision", "reference": { "en": "Ruth 2:12", "te": "\u0c30\u0c42\u0c24\u0c4d 2:12" }, "text": { "en": "The LORD recompense thy work, and a full reward be given thee of the LORD God of Israel, under whose wings thou art come to trust.", "te": "\u0c28\u0c40\u0c35\u0c41 \u0c0e\u0c35\u0c3f\u0c1f \u0c06\u0c36\u0c4d\u0c30\u0c2f\u0c2e\u0c41 \u0c2a\u0c4a\u0c02\u0c26\u0c3f\u0c28\u0c3e\u0c35\u0c4b \u0c06 \u0c07\u0c38\u0c4d\u0c30\u0c3e\u0c2f\u0c47\u0c32\u0c41 \u0c26\u0c47\u0c35\u0c41\u0c21\u0c41 \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c26\u0c40\u0c35\u0c47\u0c28\u0c4d\u0c28\u0c3f \u0c2a\u0c4d\u0c30\u0c26\u0c3e\u0c28\u0c02 \u0c1a\u0c47\u0c38\u0c4d\u0c24\u0c3e\u0c28\u0c41." } },
      { "id": "f006", "category": "hope", "reference": { "en": "Psalm 62:8", "te": "\u0c15\u0c40\u0c30\u0c4d\u0c24\u0c28\u0c32\u0c41 62:8" }, "text": { "en": "Trust in him at all times; ye people, pour out your heart before him: God is a refuge for us.", "te": "\u0c0e\u0c32\u0c4d\u0c32\u0c3e \u0c35\u0c47\u0c33\u0c32\u0c3e \u0c06\u0c2f\u0c28\u0c28\u0c3f \u0c28\u0c02\u0c2c\u0c3f\u0c02\u0c21\u0c3f; \u0c06\u0c2f\u0c28 \u0c0e\u0c26\u0c41\u0c30\u0c41\u0c28 \u0c2e\u0c40 \u0c39\u0c43\u0c26\u0c2f\u0c3e\u0c32\u0c28\u0c41 \u0c24\u0c46\u0c30\u0c3f\u0c2a\u0c3f\u0c02\u0c1a\u0c41\u0c21\u0c3f; \u0c26\u0c47\u0c35\u0c41\u0c21\u0c41 \u0c2e\u0c28\u0c15\u0c41 \u0c06\u0c36\u0c4d\u0c30\u0c2f\u0c02." } },
      { "id": "f007", "category": "healing", "reference": { "en": "Zephaniah 3:17", "te": "\u0c1c\u0c46\u0c2b\u0c28\u0c4d\u0c2f\u0c3e 3:17" }, "text": { "en": "The LORD thy God in the midst of thee is mighty; he will save, he will rejoice over thee with joy; he will rest in his love.", "te": "\u0c28\u0c3f \u0c2e\u0c27\u0c4d\u0c2f\u0c3e\u0c28 \u0c09\u0c28\u0c4d\u0c28 \u0c2f\u0c46\u0c39\u0c4b\u0c35\u0c3e \u0c2a\u0c30\u0c3e\u0c15\u0c4d\u0c30\u0c2e\u0c36\u0c3e\u0c32\u0c3f; \u0c06\u0c2f\u0c28 \u0c28\u0c3f\u0c28\u0c4d\u0c28\u0c41 \u0c30\u0c15\u0c4d\u0c37\u0c3f\u0c38\u0c4d\u0c24\u0c3e\u0c28\u0c41; \u0c06\u0c2f\u0c28 \u0c28\u0c3f\u0c2e\u0c3f\u0c24\u0c4d\u0c24\u0c2e\u0c46\u0c21\u0c32\u0c4b \u0c26\u0c3e\u0c28\u0c3f\u0c24\u0c4b \u0c32\u0c3e\u0c33\u0c3f\u0c02\u0c1a\u0c41\u0c15\u0c41\u0c28\u0c4d\u0c28\u0c3e\u0c21\u0c41." } }
    ]
  }
}
